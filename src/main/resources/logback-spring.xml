<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Structured JSON logging via logstash-logback-encoder (DESIGN.md / D-014).
         One JSON object per line, ready for ELK/Datadog ingestion. -->
    <springProperty scope="context" name="appName" source="spring.application.name"/>

    <appender name="JSON" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <customFields>{"service":"${appName:-feature-flag-service}"}</customFields>
            <includeContext>false</includeContext>
        </encoder>
    </appender>

    <!-- Human-readable pattern for local development (activated with -Dspring.profiles.active=local). -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <springProfile name="local">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

    <springProfile name="!local">
        <root level="INFO">
            <appender-ref ref="JSON"/>
        </root>
    </springProfile>
</configuration>
